# ── Servidor ──────────────────────────────────────────────────
PORT=3000
ENVIRONMENT=production

# ── Supabase ──────────────────────────────────────────────────
# Encontre em: supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # service_role key (secreta — nunca expor no frontend)
SUPABASE_ANON_KEY=eyJ...            # anon key (pública — usada no frontend)

# ── IA ────────────────────────────────────────────────────────
# Gemini: aistudio.google.com
GEMINI_API_KEY=AIza...
# Groq: console.groq.com
GROQ_API_KEY=gsk_...

# ── Email transacional ────────────────────────────────────────
# Resend: resend.com (plano gratuito: 100 emails/dia)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@vulnexusai.com

# ── Monitoramento de erros ────────────────────────────────────
# Sentry: sentry.io (plano gratuito: 5k erros/mês)
# Deixe vazio para desativar Sentry
SENTRY_DSN=https://...@sentry.io/...

# ── App ───────────────────────────────────────────────────────
APP_URL=https://vulnexusai.com
